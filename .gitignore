# ============================================================
# .gitignore 文件内容
# ============================================================
# Python
__pycache__/
*.py[cod]
*.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
dist/
build/
*.egg

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Build outputs
frontend/dist/
*.exe
*.dll
*.so
*.dylib

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# AI / local assistant configs
.agents/
.claude/
.github/

# 敏感配置（不要提交）
*.key
*.pem
.env
.env.local
.env.production
.env.*.local
!.env.example

# 本地数据（不要提交）
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite3

# 日志
*.log
logs/

# 临时文件
*.tmp
*.temp
.cache/

# 测试输出
htmlcov/
.coverage
.pytest_cache/

# 输出文件
output/
outputs/
*.xlsx
*.xls
*.csv

# 前端环境变量
frontend/.env
frontend/.env.*
!frontend/.env.example

# 后端环境变量
backend/.env
backend/.env.*
!backend/.env.example