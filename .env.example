# ==============================
# tOS Quality Workbench 环境变量配置
# 复制此文件为 .env 并填写实际值
# ==============================

# ── 端口配置 ──
PORT=8018                          # 后端 API 端口
HOST=0.0.0.0                       # 后端监听地址
VITE_FRONTEND_PORT=8088            # 前端开发服务器端口
VITE_BACKEND_PORT=8018             # 前端代理目标端口（开发模式）

# ── 跨域配置 ──
CORS_ORIGINS=http://localhost:8088 # 允许的前端来源（逗号分隔多个）

# ── 运行模式 ──
DEBUG=true                         # true=开发模式(热重载), false=生产模式

# ── 飞书应用（按需填写） ──
FEISHU_APP_ID=
FEISHU_APP_SECRET=
